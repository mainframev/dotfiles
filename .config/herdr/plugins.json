  {
    "plugin_id": "worktrunk",
    "name": "Worktrunk",
    "version": "0.1.0",
    "min_herdr_version": "0.7.0",
    "description": "Switch, create, or remove git worktrees via worktrunk",
    "manifest_path": "/Users/rejuv/dotfiles/.config/herdr/plugins/github/worktrunk-7fb519583f31/herdr-plugin.toml",
    "plugin_root": "/Users/rejuv/dotfiles/.config/herdr/plugins/github/worktrunk-7fb519583f31",
    "enabled": true,
    "platforms": [
      "macos",
      "linux"
    ],
    "actions": [
      {
        "id": "open",
        "title": "Worktree: switch / create",
        "contexts": [
          "workspace"
        ],
        "command": [
          "bash",
          "-c",
          "cwd=$(jq -r '.workspace_cwd // .focused_pane_cwd' <<<\"$HERDR_PLUGIN_CONTEXT_JSON\"); exec \"$HERDR_BIN_PATH\" plugin pane open --plugin \"$HERDR_PLUGIN_ID\" --entrypoint picker --placement split --direction down --cwd \"$cwd\" --focus"
        ]
      },
      {
        "id": "remove",
        "title": "Worktree: remove",
        "contexts": [
          "workspace"
        ],
        "command": [
          "bash",
          "-c",
          "cwd=$(jq -r '.workspace_cwd // .focused_pane_cwd' <<<\"$HERDR_PLUGIN_CONTEXT_JSON\"); exec \"$HERDR_BIN_PATH\" plugin pane open --plugin \"$HERDR_PLUGIN_ID\" --entrypoint remover --placement split --direction down --cwd \"$cwd\" --focus"
        ]
      }
    ],
    "panes": [
      {
        "id": "picker",
        "title": "Worktrunk",
        "placement": "split",
        "command": [
          "bash",
          "-c",
          "exec bash \"$HERDR_PLUGIN_ROOT/picker.sh\""
        ]
      },
      {
        "id": "remover",
        "title": "Worktrunk — remove",
        "placement": "split",
        "command": [
          "bash",
          "-c",
          "exec bash \"$HERDR_PLUGIN_ROOT/remove.sh\""
        ]
      }
    ],
    "source": {
      "kind": "github",
